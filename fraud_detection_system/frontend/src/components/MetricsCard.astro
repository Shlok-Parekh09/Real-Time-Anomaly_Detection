---
interface Props {
  title: string;
  value: string | number;
  secondary?: string;
  icon: any;
  colorClass: string;
}

const { title, value, secondary, icon: Icon, colorClass } = Astro.props;
---

<div class="bg-white border border-slate-200 rounded-lg p-5 flex flex-col justify-between hover:shadow-md hover:border-slate-300 transition-all duration-200 group">
  <div class="flex items-center justify-between">
    <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">{title}</span>
    <div class={`p-2 rounded ${colorClass} group-hover:scale-105 transition-transform shrink-0`}>
      <Icon class="w-4.5 h-4.5" />
    </div>
  </div>
  <div class="mt-3 flex items-baseline justify-between gap-2">
    <p class="text-2xl font-bold text-slate-900 tracking-tight metrics-value">{value}</p>
    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider shrink-0 metrics-secondary">{secondary || ''}</span>
  </div>
</div>
