---
import Layout from '../../layouts/Layout.astro';
import { 
  ShieldCheck, AlertTriangle, CheckCircle2, ChevronLeft, Download, 
  Printer, Languages, Info, FileText, AlertCircle, FileSearch, 
  ExternalLink, ArrowRight, CornerDownRight, History, MoreVertical,
  Scale, HardDrive, Cpu, FileCheck, Eye, Loader2, RefreshCcw
} from "lucide-astro";
---

<Layout title="Investigation Workspace | Anobis" activeTab="investigations">
  <div id="investigation-container" class="flex h-full overflow-hidden">
    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col min-w-0 bg-slate-50 overflow-hidden">
      <!-- Toolbar -->
      <div class="h-12 bg-white border-b border-slate-200 flex items-center justify-between px-6 flex-shrink-0">
        <div class="flex items-center gap-4">
          <a href="/investigations" class="p-1 text-slate-400 hover:text-slate-900 transition-colors">
            <ChevronLeft class="w-5 h-5" />
          </a>
          <div class="h-4 w-px bg-slate-200"></div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-widest">Case: <span class="text-slate-900" id="display-id">Loading…</span></p>
          <div class="h-4 w-px bg-slate-200"></div>
          <span id="header-status-pill" class="status-pill">Loading…</span>
        </div>
        
        <div class="flex items-center gap-2">
          <button id="refresh-btn" class="p-1.5 text-slate-400 hover:text-slate-600 rounded">
            <RefreshCcw class="w-4 h-4" />
          </button>
          <button id="export-report-btn" class="btn-secondary py-1 text-xs">
            <Printer class="w-3.5 h-3.5" />
            Export Report
          </button>
          <button id="resolve-btn" class="btn-primary py-1 text-xs">
            Mark as Resolved
          </button>
        </div>
      </div>

      <!-- Analysis Progress (Phase 4) -->
      <div id="analysis-progress-view" class="hidden flex-1 flex flex-col items-center justify-center p-8 text-center bg-white">
        <div class="max-w-md w-full space-y-8">
           <div class="relative w-24 h-24 mx-auto">
             <div class="absolute inset-0 border-4 border-slate-100 rounded-full"></div>
             <div id="progress-spinner" class="absolute inset-0 border-4 border-bank-blue rounded-full border-t-transparent animate-spin"></div>
             <div class="absolute inset-0 flex items-center justify-center text-sm font-bold text-slate-900" id="progress-percent">0%</div>
           </div>
           
           <div class="space-y-2">
             <h2 class="text-xl font-bold text-slate-900">Forensic Analysis in Progress</h2>
             <p class="text-slate-500 text-sm font-medium" id="current-stage-msg">Initializing extraction engine…</p>
           </div>

           <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
             <div id="progress-bar-fill" class="h-full bg-bank-blue transition-all duration-500" style="width: 0%"></div>
           </div>

            <div class="p-4 bg-slate-50 border border-slate-200 rounded-lg text-left">
              <h4 class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2 text-center">Technical Progress Log</h4>
              <div id="technical-status-log" aria-live="polite" class="space-y-1 text-[11px] text-slate-600 font-medium font-mono">
                <!-- Dynamically filled during status polling -->
              </div>
            </div>
        </div>
      </div>

      <!-- Results View (Step 6 Document Workbench Split View) -->
      <div id="results-view" class="hidden flex-1 flex flex-row overflow-hidden h-full">
        
        <!-- Left Side: Investigation Details & Findings (65% width) -->
        <div class="w-[65%] h-full overflow-y-auto p-6 space-y-6 bg-slate-50 border-r border-slate-200">
          
          <!-- 1. AI Summary Section -->
          <div class="bg-white p-6 rounded-lg border border-slate-200 shadow-sm space-y-4">
            <div class="flex items-center gap-3">
              <div id="summary-icon-container" class="p-2.5 bg-slate-100 text-slate-800 rounded-md">
                <ShieldCheck class="w-6 h-6" />
              </div>
              <div>
                <h2 class="text-xl font-bold text-slate-900 leading-tight" id="res-title">Forensic Audit & Analysis Report</h2>
                <p class="text-slate-500 text-sm font-medium" id="res-context">Loading context…</p>
              </div>
            </div>
            
            <div class="bg-slate-50/50 p-5 rounded-lg border border-slate-200/60 relative group">
              <div id="summary-content" class="text-sm text-slate-700 leading-relaxed font-medium pr-10">
                <!-- English Summary -->
              </div>
              
              <!-- English TTS Controls -->
              <div class="flex items-center gap-2 mt-3 pt-3 border-t border-slate-200/50">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mr-1 select-none">English Audio:</span>
                <button id="tts-en-play" class="px-2.5 py-1 text-[10px] font-bold bg-slate-200 hover:bg-slate-300 text-slate-700 rounded transition-all cursor-pointer select-none font-sans">▶ Play</button>
                <button id="tts-en-pause" class="px-2.5 py-1 text-[10px] font-bold bg-slate-200 hover:bg-slate-300 text-slate-700 rounded transition-all cursor-pointer select-none font-sans">⏸ Pause</button>
                <button id="tts-en-stop" class="px-2.5 py-1 text-[10px] font-bold bg-slate-200 hover:bg-slate-300 text-slate-700 rounded transition-all cursor-pointer select-none font-sans">⏹ Stop</button>
              </div>

              <div id="hindi-summary-content" class="hidden mt-4 pt-4 border-t border-slate-200 text-sm text-slate-700 leading-relaxed font-medium">
                <!-- Hindi Summary -->
              </div>

              <!-- Hindi TTS Controls -->
              <div id="tts-hi-controls" class="hidden flex items-center gap-2 mt-3 pt-3 border-t border-slate-200/50">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wide mr-1 select-none">Hindi Audio:</span>
                <button id="tts-hi-play" class="px-2.5 py-1 text-[10px] font-bold bg-slate-200 hover:bg-slate-300 text-slate-700 rounded transition-all cursor-pointer select-none font-sans">▶ Play</button>
                <button id="tts-hi-pause" class="px-2.5 py-1 text-[10px] font-bold bg-slate-200 hover:bg-slate-300 text-slate-700 rounded transition-all cursor-pointer select-none font-sans">⏸ Pause</button>
                <button id="tts-hi-stop" class="px-2.5 py-1 text-[10px] font-bold bg-slate-200 hover:bg-slate-300 text-slate-700 rounded transition-all cursor-pointer select-none font-sans">⏹ Stop</button>
              </div>

              <button id="toggle-hindi" class="absolute top-4 right-4 p-1.5 text-slate-400 hover:text-slate-600 hover:bg-white rounded transition-all shadow-sm cursor-pointer" title="Translate to Hindi">
                <Languages class="w-4 h-4" />
              </button>
            </div>
          </div>

          <!-- 2. Risk Overview Section -->
          <div class="bg-white p-6 rounded-lg border border-slate-200 shadow-sm space-y-6">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider border-b border-slate-100 pb-3">Risk & Assessment Overview</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-center">
              <!-- Circular Trust Score Gauge -->
              <div class="flex flex-col items-center justify-center text-center p-4 bg-slate-50/50 rounded-lg border border-slate-100">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3">Trust Score</span>
                <div class="relative w-24 h-24 flex items-center justify-center">
                  <svg class="w-full h-full transform -rotate-90">
                    <circle cx="48" cy="48" r="42" stroke="currentColor" stroke-width="6" fill="transparent" class="text-slate-100" />
                    <circle id="trust-circle" cx="48" cy="48" r="42" stroke="currentColor" stroke-width="6" fill="transparent" stroke-dasharray="263.8" stroke-dashoffset="263.8" class="text-slate-400 transition-all duration-1000" />
                  </svg>
                  <span class="absolute text-2xl font-bold text-slate-900 tracking-tighter" id="trust-score-text">--%</span>
                </div>
                <div class="mt-3 space-y-0.5">
                  <p id="res-status-text" class="text-xs font-bold text-slate-500 uppercase tracking-tight">ANALYZING</p>
                  <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest" id="res-recommendation">…</p>
                </div>
              </div>

              <!-- Recommendation / Decision -->
              <div class="md:col-span-2 space-y-4">
                <div class="p-4 bg-slate-900 text-white rounded-lg flex items-center justify-between shadow-sm">
                  <div>
                    <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Final Assessment</span>
                    <p id="final-decision-badge" class="text-sm font-black uppercase tracking-wider text-rose-400">Loading…</p>
                  </div>
                  <div class="text-right">
                    <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Calculated Risk Level</span>
                    <p id="risk-score-text" class="text-xs font-bold text-slate-200">Checking…</p>
                  </div>
                </div>

                <div class="p-4 bg-slate-50/50 rounded-lg border border-slate-100 space-y-1">
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">AI Risk Narrative</span>
                  <p id="ai-risk-narrative" class="text-xs text-slate-700 leading-relaxed font-medium">Analyzing risk factors…</p>
                </div>
              </div>
            </div>

            <!-- Verification Checkpoint Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 border-t border-slate-100 pt-6">
              <!-- Identity Alignment Card -->
              <div class="p-4 bg-slate-50/50 border border-slate-200/60 rounded-lg flex flex-col justify-between space-y-3">
                <div class="space-y-2">
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Identity Alignment</span>
                    <span id="id-status-badge" class="px-2 py-0.5 text-[10px] font-bold rounded uppercase tracking-widest bg-slate-200 text-slate-700">Checking…</span>
                  </div>
                  <p id="id-explanation" class="text-xs text-slate-600 font-medium leading-relaxed font-sans">Checking document details…</p>
                </div>
                <div class="border-t border-slate-200/60 pt-2 space-y-1">
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Actionable Check</span>
                  <p id="id-recommendation" class="text-xs text-slate-800 font-bold leading-tight font-sans">Pending check…</p>
                </div>
              </div>

              <!-- Financial Consistency Card -->
              <div class="p-4 bg-slate-50/50 border border-slate-200/60 rounded-lg flex flex-col justify-between space-y-3">
                <div class="space-y-2">
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Financial Math</span>
                    <span id="fin-status-badge" class="px-2 py-0.5 text-[10px] font-bold rounded uppercase tracking-widest bg-slate-200 text-slate-700">Checking…</span>
                  </div>
                  <p id="fin-explanation" class="text-xs text-slate-600 font-medium leading-relaxed font-sans">Verifying income calculations…</p>
                </div>
                <div class="border-t border-slate-200/60 pt-2 space-y-1">
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Actionable Check</span>
                  <p id="fin-recommendation" class="text-xs text-slate-800 font-bold leading-tight font-sans">Pending check…</p>
                </div>
              </div>

              <!-- Metadata Analysis Card -->
              <div class="p-4 bg-slate-50/50 border border-slate-200/60 rounded-lg flex flex-col justify-between space-y-3">
                <div class="space-y-2">
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Metadata Forensics</span>
                    <span id="meta-status-badge" class="px-2 py-0.5 text-[10px] font-bold rounded uppercase tracking-widest bg-slate-200 text-slate-700">Checking…</span>
                  </div>
                  <p id="meta-explanation" class="text-xs text-slate-600 font-medium leading-relaxed font-sans">Analyzing tool signatures…</p>
                </div>
                <div class="border-t border-slate-200/60 pt-2 space-y-1">
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Actionable Check</span>
                  <p id="meta-recommendation" class="text-xs text-slate-800 font-bold leading-tight font-sans">Pending check…</p>
                </div>
              </div>
            </div>

            <!-- Manual Checklist -->
            <div class="border-t border-slate-100 pt-6 space-y-3">
              <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Recommended Manual Verifications</span>
              <div id="checklist-container" class="grid grid-cols-1 md:grid-cols-2 gap-2 text-xs font-semibold text-slate-600">
                <!-- Checklist item list -->
              </div>
            </div>
          </div>

          <!-- 3. Findings Section -->
          <div class="bg-white p-6 rounded-lg border border-slate-200 shadow-sm space-y-4">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider border-b border-slate-100 pb-3 flex items-center gap-1.5">
              <AlertCircle class="w-4 h-4 text-slate-700" />
              Forensic Findings & Anomalies
            </h3>
            <div id="findings-container" class="space-y-4">
              <!-- Grouped Findings -->
            </div>
          </div>

          <!-- 4. Evidence Section -->
          <div class="bg-white p-6 rounded-lg border border-slate-200 shadow-sm space-y-4">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider border-b border-slate-100 pb-3 flex items-center gap-1.5">
              <FileCheck class="w-4 h-4 text-slate-700" />
              Supporting Evidence & Technical Matches
            </h3>
            <div class="p-5 bg-slate-900 text-white rounded-lg flex flex-col justify-between shadow-sm">
              <div>
                <h4 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3">Evidence Quick-List</h4>
                <div class="space-y-2.5 max-h-[220px] overflow-y-auto" id="evidence-summary-list">
                  <!-- Evidence Quick List -->
                </div>
              </div>
            </div>
          </div>

          <!-- 5. Deep Analysis Section -->
          <div class="bg-white p-6 rounded-lg border border-slate-200 shadow-sm space-y-4">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider border-b border-slate-100 pb-3 flex items-center gap-1.5">
              <Cpu class="w-4 h-4 text-slate-700" />
              Deep Analysis & AI Reasoning
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <!-- Cross-document Observations -->
              <div class="p-4 bg-slate-50 border border-slate-200 rounded-lg space-y-2">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Cross-Document Observations</span>
                <p id="ai-evidence-analysis" class="text-xs text-slate-700 leading-relaxed font-medium">Analyzing cross-document signals...</p>
              </div>
              <!-- AI Forensic Reasoning -->
              <div class="p-4 bg-slate-50 border border-slate-200 rounded-lg space-y-2">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">AI Forensic Reasoning</span>
                <p id="ai-forensic-reasoning" class="text-xs text-slate-700 leading-relaxed font-medium font-sans">Evaluating reasoning factors...</p>
              </div>
              <!-- Case Narrative -->
              <div class="p-4 bg-slate-50 border border-slate-200 rounded-lg space-y-2">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Evidence & Case Narrative</span>
                <p id="ai-human-explanation" class="text-xs text-slate-700 leading-relaxed font-medium font-sans">Compiling evidence summary...</p>
              </div>
            </div>
          </div>

          <!-- 6. Knowledge Base Section -->
          <div class="bg-white border border-slate-200 rounded-lg p-6 space-y-4 shadow-sm">
            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
              <h3 class="font-bold text-slate-900 text-sm uppercase tracking-wider flex items-center gap-1.5">
                <HardDrive class="w-4 h-4 text-slate-700" />
                Reference Library & Knowledge Base
              </h3>
              <!-- Tooltip Explanation -->
              <div class="relative group cursor-help text-slate-400 hover:text-slate-600">
                <Info class="w-4 h-4" />
                <div class="absolute bottom-full right-0 mb-2 w-56 p-3 bg-slate-950 text-white text-[10px] rounded-lg shadow-lg opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity z-50 leading-relaxed font-medium">
                  Promoting verified cases to the Reference Library allows pattern similarity checks to match new documents against verified templates.
                </div>
              </div>
            </div>
            
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <button role="switch" aria-checked="false" id="approve-reference-btn" class="relative inline-flex h-5 w-9 shrink-0 items-center rounded-full transition-colors duration-200 focus:outline-none focus:ring-1 focus:ring-offset-1 focus:ring-blue-600 bg-slate-200 cursor-pointer">
                  <span class="pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white shadow-sm ring-0 transition-transform duration-200 translate-x-0.5"></span>
                </button>
                <span class="text-sm font-bold text-slate-700 font-sans">Promote to Trusted Reference</span>
              </div>
              <span id="reference-status-text" class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Not Promoted to Reference</span>
            </div>
          </div>      

          <!-- 7. Document Viewer Section -->
          <div class="bg-white border border-slate-200 rounded-lg p-6 space-y-4 shadow-sm">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider border-b border-slate-100 pb-3 flex items-center gap-1.5">
              <FileText class="w-4 h-4 text-slate-700" />
              Forensic Document Viewer
            </h3>
            <div class="h-[480px] bg-slate-50 border border-slate-200 rounded-lg flex flex-col overflow-hidden">
              <!-- Horizontally scrollable document tabs -->
              <div id="large-doc-selector" class="flex items-center bg-slate-100 border-b border-slate-200 overflow-x-auto scrollbar-none flex-shrink-0">
                <!-- Tab chips dynamically loaded -->
              </div>
              <div id="panel-view" class="flex-1 bg-white overflow-hidden flex flex-col p-2">
                <iframe id="doc-iframe" class="w-full h-full border border-slate-200 rounded bg-white shadow-inner" src=""></iframe>
              </div>
            </div>
          </div>

        </div>

        <!-- Right Side: Forensic Document Workbench (35% width) -->
        <div class="w-[35%] h-full flex flex-col bg-white border-l border-slate-200 overflow-hidden">
          
          <!-- Workbench Header -->
          <div class="p-4 border-b border-slate-200 bg-slate-50 flex-shrink-0">
            <h3 class="text-xs font-bold text-slate-900 uppercase tracking-wider flex items-center gap-1.5">
              <FileSearch class="w-4 h-4 text-slate-700" />
              Forensic Document Workbench
            </h3>
          </div>

          <!-- Properties & Entity Extraction (Middle Scrollable) -->
          <div class="flex-1 overflow-y-auto p-4 space-y-5 bg-white">
            <div>
              <h4 class="font-bold text-slate-900 border-b border-slate-100 pb-1.5 mb-2.5 uppercase tracking-wider text-[10px]">Entity Extraction</h4>
              <div id="entities-table-body" class="space-y-1.5 text-xs font-medium text-slate-700">
                <!-- Entities key-value pairs -->
              </div>
            </div>
            <div>
              <h4 class="font-bold text-slate-900 border-b border-slate-100 pb-1.5 mb-2.5 uppercase tracking-wider text-[10px]">OCR Accuracy & Metadata</h4>
              <div id="ocr-table-body" class="space-y-1.5 text-xs font-medium text-slate-700">
                <!-- OCR details -->
              </div>
            </div>
          </div>

        </div>

      </div>
      <!-- Loading State -->
      <div id="global-loading" class="flex-1 flex flex-col items-center justify-center bg-white">
        <Loader2 class="w-10 h-10 text-slate-700 animate-spin mb-6" />
        <p id="global-loading-msg" class="text-slate-600 text-sm font-semibold tracking-wide fade-text">Initializing Investigation Context…</p>
      </div>

      <!-- Error State -->
      <div id="global-error" class="hidden flex-1 flex flex-col items-center justify-center bg-white p-8 text-center">
        <div class="w-16 h-16 bg-rose-50 rounded-full flex items-center justify-center mb-4">
          <AlertCircle class="w-8 h-8 text-rose-500" />
        </div>
        <h3 class="text-lg font-bold text-slate-900">Forensic Link Failed</h3>
        <p id="global-error-msg" class="text-slate-500 mt-1 max-w-xs">We couldn't retrieve the analysis results for this case.</p>
        <button id="retry-fetch" class="mt-6 btn-secondary cursor-pointer">
          <RefreshCcw class="w-4 h-4" />
          Retry Connection
        </button>
      </div>

    </div>
  </div>
</Layout>

<style is:global>
  @media print {
    aside, header, #refresh-btn, #export-report-btn, .btn-primary, #doc-selector, #doc-type-badge, select, .w-5\/12 {
      display: none !important;
    }
    #investigation-container {
      display: block !important;
      overflow: visible !important;
      height: auto !important;
    }
    #results-view {
      display: block !important;
      overflow: visible !important;
      height: auto !important;
      width: 100% !important;
    }
    .w-7\/12 {
      width: 100% !important;
      border-right: none !important;
      padding: 0 !important;
      overflow: visible !important;
      height: auto !important;
    }
    .investigation-card {
      border: 1px solid #cbd5e1 !important;
      box-shadow: none !important;
      page-break-inside: avoid;
    }
  }
</style>

<script>
  import { api } from '../../services/api';
  document.addEventListener('astro:page-load', () => {


  // Helper to format backend enums into human-readable strings
  function formatEnum(val: string | null | undefined): string {
    if (!val) return 'N/A';
    const mapping: Record<string, string> = {
      'MANUAL_REVIEW': 'Manual Review Required',
      'AUTO_APPROVE': 'Auto Approved',
      'AUTO_REJECT': 'Auto Rejected',
      'CROSS_DOC': 'Cross-Document Inconsistency',
      'OCR_FAILED': 'OCR Extraction Failed',
      'LOW_CONFIDENCE': 'Scan Resolution Alert',
      'METADATA_TAMPERING': 'Potential Metadata Manipulation',
      'PIXEL_TAMPERING': 'Potential Image Tampering',
      'FONT_INCONSISTENCY': 'Font Consistency Error',
      'PENDING': 'Pending',
      'PROCESSING': 'Analyzing',
      'IN_PROGRESS': 'In Progress',
      'COMPLETED': 'Analysis Complete',
      'FAILED': 'Failed',
      'PASS': 'Verified',
      'FAIL': 'Issue Detected',
      'HIGH': 'High',
      'MEDIUM': 'Medium',
      'LOW': 'Low',
      'CRITICAL': 'Critical',
    };
    const mapped = mapping[val.toUpperCase()];
    if (mapped) return mapped;
    return val.replace(/_/g, ' ').toLowerCase().replace(/\b\w/g, c => c.toUpperCase());
  }
  
  // Elements
  const displayId = document.getElementById('display-id');
  const analysisProgressView = document.getElementById('analysis-progress-view');
  const resultsView = document.getElementById('results-view');
  const globalLoading = document.getElementById('global-loading');
  const globalError = document.getElementById('global-error');
  const globalErrorMsg = document.getElementById('global-error-msg');
  const retryFetch = document.getElementById('retry-fetch');
  const refreshBtn = document.getElementById('refresh-btn');
  const exportReportBtn = document.getElementById('export-report-btn');
  
  const currentStageMsg = document.getElementById('current-stage-msg');
  const progressPercent = document.getElementById('progress-percent');
  const progressBarFill = document.getElementById('progress-bar-fill');
  
  const resTitle = document.getElementById('res-title');
  const resContext = document.getElementById('res-context');
  const summaryContent = document.getElementById('summary-content');
  const hindiSummaryContent = document.getElementById('hindi-summary-content');
  const toggleHindi = document.getElementById('toggle-hindi');
  const resStatusText = document.getElementById('res-status-text');
  const resRecommendation = document.getElementById('res-recommendation');
  const trustScoreText = document.getElementById('trust-score-text');
  const trustCircle = document.getElementById('trust-circle') as unknown as SVGCircleElement;
