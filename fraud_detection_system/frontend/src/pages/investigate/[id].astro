---
import Layout from '../../layouts/Layout.astro';
import { 
  ShieldCheck, AlertTriangle, CheckCircle2, ChevronLeft, Download, 
  Printer, Languages, Info, FileText, AlertCircle, FileSearch, 
  ExternalLink, ArrowRight, CornerDownRight, History, MoreVertical,
  Scale, HardDrive, Cpu, FileCheck, Eye
} from "lucide-astro";

export function getStaticPaths() {
  return [
    { params: { id: 'INV-2026-001' } },
    { params: { id: 'INV-2026-002' } },
    { params: { id: 'INV-2026-NEW' } },
  ];
}

const { id } = Astro.params;

const files = [
  { name: 'BankStatement_Q1.pdf', status: 'verified', active: true },
  { name: 'Payslip_March2026.png', status: 'suspicious', active: false },
  { name: 'Aadhaar_Card.pdf', status: 'fraudulent', active: false },
  { name: 'PAN_Card.jpg', status: 'verified', active: false },
];

const findings = {
  fraudulent: [
    { title: 'Metadata Manipulation', evidence: 'Creation timestamp (2026-05-12) differs from modification history (2024-02-10). File structure indicates recent PDF injection.', confidence: '94%', file: 'Aadhaar_Card.pdf' }
  ],
  suspicious: [
    { title: 'Inconsistent Font Rendering', evidence: 'Currency symbols in the total amount field use a font family not present in the rest of the document.', confidence: '78%', file: 'Payslip_March2026.png' },
    { title: 'Suspected PDF Layering', evidence: 'Hidden text layers detected beneath visible income values. Indicates possible manual overwrite.', confidence: '82%', file: 'BankStatement_Q1.pdf' }
  ],
  verified: [
    { title: 'Structural Integrity', evidence: 'Document structure conforms to standard financial institution templates. No anomalous headers detected.', file: 'BankStatement_Q1.pdf' },
    { title: 'Identity Correlation', evidence: 'Name and DOB match across identity documents and bank records.', file: 'PAN_Card.jpg' }
  ]
};
---

<Layout title={`Investigation ${id} | Anobis`} activeTab="investigations">
  <div class="flex h-full overflow-hidden">
    <!-- File Sidebar -->
    <aside class="w-72 border-r border-slate-200 bg-white flex flex-col flex-shrink-0">
      <div class="p-4 border-b border-slate-200 flex items-center justify-between">
        <h2 class="text-xs font-bold text-slate-900 uppercase tracking-widest">Uploaded Files</h2>
        <span class="text-[10px] font-bold text-slate-400 bg-slate-100 px-1.5 py-0.5 rounded">{files.length}</span>
      </div>
      <div class="flex-1 overflow-y-auto p-2 space-y-1">
        {files.map((file) => (
          <button class={`w-full flex items-center justify-between p-3 rounded-md transition-all text-left ${file.active ? 'bg-blue-50 border border-blue-100' : 'hover:bg-slate-50 border border-transparent'}`}>
            <div class="flex items-center gap-3 truncate">
              {file.status === 'verified' && <div class="w-2 h-2 rounded-full bg-emerald-500 flex-shrink-0"></div>}
              {file.status === 'suspicious' && <div class="w-2 h-2 rounded-full bg-amber-500 flex-shrink-0"></div>}
              {file.status === 'fraudulent' && <div class="w-2 h-2 rounded-full bg-rose-500 flex-shrink-0"></div>}
              <span class={`text-sm truncate ${file.active ? 'font-bold text-bank-blue' : 'font-medium text-slate-600'}`}>{file.name}</span>
            </div>
            {file.active && <Eye class="w-3.5 h-3.5 text-bank-blue flex-shrink-0" />}
          </button>
        ))}
        
        <button class="w-full flex items-center justify-center gap-2 p-3 mt-4 border border-dashed border-slate-200 rounded-md text-slate-400 text-xs font-bold uppercase tracking-wider hover:border-bank-blue hover:text-bank-blue transition-all">
          <Download class="w-3 h-3" />
          Add More Docs
        </button>
      </div>
    </aside>

    <!-- Workspace -->
    <div class="flex-1 flex flex-col min-w-0 bg-slate-50 overflow-hidden">
      <!-- Toolbar -->
      <div class="h-12 bg-white border-b border-slate-200 flex items-center justify-between px-6 flex-shrink-0">
        <div class="flex items-center gap-4">
          <a href="/" class="p-1 text-slate-400 hover:text-slate-900 transition-colors">
            <ChevronLeft class="w-5 h-5" />
          </a>
          <div class="h-4 w-px bg-slate-200"></div>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-widest">Case: <span class="text-slate-900">{id}</span></p>
          <div class="h-4 w-px bg-slate-200"></div>
          <span class="status-pill-red">High Risk Detected</span>
        </div>
        
        <div class="flex items-center gap-2">
          <button class="btn-secondary py-1 text-xs">
            <Printer class="w-3.5 h-3.5" />
            Export Report
          </button>
          <button class="btn-primary py-1 text-xs">
            Mark as Resolved
          </button>
        </div>
      </div>

      <!-- Main Workspace Scroll Area -->
      <div class="flex-1 overflow-y-auto p-8">
        <div class="max-w-6xl mx-auto space-y-8">
          
          <!-- Summary Header -->
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
              <div class="flex items-start justify-between bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                <div class="space-y-4 flex-1">
                  <div class="flex items-center gap-3">
                    <div class="p-2 bg-rose-50 text-rose-600 rounded-lg">
                      <ShieldCheck class="w-6 h-6" />
                    </div>
                    <div>
                      <h2 class="text-xl font-bold text-slate-900">Investigation Summary</h2>
                      <p class="text-slate-500 text-sm font-medium">Forensic Analysis of Multiple Document Submission</p>
                    </div>
                  </div>
                  
                  <div class="bg-slate-50 p-4 rounded-lg border border-slate-100 relative group">
                    <p class="text-sm text-slate-700 leading-relaxed font-medium pr-10">
                      "Multiple anomalies detected across three documents. The submitted payslip appears modified after generation and contains values inconsistent with the provided bank statement. Identity document (Aadhaar) shows signs of metadata tampering in the creation timestamp."
                    </p>
                    <button class="absolute top-3 right-3 p-1.5 text-slate-400 hover:text-bank-blue hover:bg-white rounded transition-all shadow-sm" title="Translate to Hindi">
                      <Languages class="w-4 h-4" />
                    </button>
                  </div>
                </div>
              </div>

              <!-- Cross-Document Consistency -->
              <div class="investigation-card p-6 bg-white">
                <div class="flex items-center gap-2 mb-6">
                  <Scale class="w-5 h-5 text-bank-blue" />
                  <h3 class="font-bold text-slate-900 uppercase tracking-wider text-sm">Cross-Document Consistency Analysis</h3>
                </div>
                
                <div class="space-y-6">
                  <div class="flex items-start gap-4 p-4 bg-rose-50 border border-rose-100 rounded-lg">
                    <div class="p-2 bg-rose-100 text-rose-600 rounded">
                      <AlertCircle class="w-4 h-4" />
                    </div>
                    <div class="flex-1 grid grid-cols-1 md:grid-cols-3 gap-6">
                      <div class="md:col-span-2">
                        <p class="text-sm font-bold text-slate-900">Income Mismatch Detected</p>
                        <p class="text-xs text-slate-600 mt-1">Comparison between reported monthly income and bank deposits reveals a significant variance of 44%.</p>
                      </div>
                      <div class="flex flex-col gap-2 border-l border-rose-200 pl-6">
                        <div>
                          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Payslip.pdf</p>
                          <p class="text-sm font-bold text-rose-600">₹75,000 / month</p>
                        </div>
                        <div>
                          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">BankStatement.pdf</p>
                          <p class="text-sm font-bold text-rose-600">₹42,000 / month avg</p>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="flex items-start gap-4 p-4 bg-amber-50 border border-amber-100 rounded-lg">
                    <div class="p-2 bg-amber-100 text-amber-600 rounded">
                      <AlertTriangle class="w-4 h-4" />
                    </div>
                    <div class="flex-1 grid grid-cols-1 md:grid-cols-3 gap-6">
                      <div class="md:col-span-2">
                        <p class="text-sm font-bold text-slate-900">Name Inconsistency</p>
                        <p class="text-xs text-slate-600 mt-1">Slight variation in name spelling detected across KYC documents and financial records.</p>
                      </div>
                      <div class="flex flex-col gap-2 border-l border-amber-200 pl-6">
                        <div>
                          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">ID Document</p>
                          <p class="text-sm font-bold text-amber-700 font-mono">RAJESH KUMAR</p>
                        </div>
                        <div>
                          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Bank Statement</p>
                          <p class="text-sm font-bold text-amber-700 font-mono">RAJESH KUMAAR</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Score Panel -->
            <div class="space-y-6">
              <div class="investigation-card p-8 flex flex-col items-center text-center bg-white">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Final Trust Score</p>
                <div class="relative w-32 h-32 flex items-center justify-center">
                  <svg class="w-full h-full transform -rotate-90">
                    <circle cx="64" cy="64" r="58" stroke="currentColor" stroke-width="8" fill="transparent" class="text-slate-100" />
                    <circle cx="64" cy="64" r="58" stroke="currentColor" stroke-width="8" fill="transparent" stroke-dasharray="364.4" stroke-dashoffset="240.5" class="text-rose-500" />
                  </svg>
                  <span class="absolute text-3xl font-bold text-slate-900 tracking-tighter">34%</span>
                </div>
                <div class="mt-6 space-y-1">
                  <p class="text-lg font-bold text-rose-600 uppercase tracking-tight">Fraudulent</p>
                  <p class="text-xs text-slate-500 font-medium">Critical anomalies detected</p>
                </div>
              </div>

              <div class="investigation-card bg-slate-900 text-white p-6">
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Recommended Actions</h3>
                <div class="space-y-3">
                  <button class="w-full flex items-center justify-between p-3 bg-slate-800 rounded-md hover:bg-slate-700 transition-all text-left">
                    <span class="text-sm font-medium">Escalate for Manual Review</span>
                    <CornerDownRight class="w-4 h-4 text-slate-500" />
                  </button>
                  <button class="w-full flex items-center justify-between p-3 bg-slate-800 rounded-md hover:bg-slate-700 transition-all text-left text-rose-400">
                    <span class="text-sm font-medium">Reject Application</span>
                    <AlertCircle class="w-4 h-4" />
                  </button>
                  <button class="w-full flex items-center justify-between p-3 bg-slate-800 rounded-md hover:bg-slate-700 transition-all text-left">
                    <span class="text-sm font-medium">Request Additional Docs</span>
                    <History class="w-4 h-4 text-slate-500" />
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Detailed Findings -->
          <div class="space-y-6">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider">Analysis Breakdown</h3>
            
            <!-- Analysis Pillars -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <div class="investigation-card p-4 bg-white flex flex-col gap-3">
                <div class="flex items-center gap-2">
                  <HardDrive class="w-4 h-4 text-slate-400" />
                  <p class="text-[10px] font-bold text-slate-500 uppercase">Metadata</p>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-xs font-bold text-slate-900">Forensics</span>
                  <span class="text-[10px] font-bold text-rose-600">TAMPERED</span>
                </div>
              </div>
              <div class="investigation-card p-4 bg-white flex flex-col gap-3">
                <div class="flex items-center gap-2">
                  <Cpu class="w-4 h-4 text-slate-400" />
                  <p class="text-[10px] font-bold text-slate-500 uppercase">Structural</p>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-xs font-bold text-slate-900">Integrity Check</span>
                  <span class="text-[10px] font-bold text-emerald-600">VALID</span>
                </div>
              </div>
              <div class="investigation-card p-4 bg-white flex flex-col gap-3">
                <div class="flex items-center gap-2">
                  <FileCheck class="w-4 h-4 text-slate-400" />
                  <p class="text-[10px] font-bold text-slate-500 uppercase">Content</p>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-xs font-bold text-slate-900">Validation</span>
                  <span class="text-[10px] font-bold text-amber-600">ANOMALOUS</span>
                </div>
              </div>
              <div class="investigation-card p-4 bg-white flex flex-col gap-3">
                <div class="flex items-center gap-2">
                  <FileSearch class="w-4 h-4 text-slate-400" />
                  <p class="text-[10px] font-bold text-slate-500 uppercase">Authenticity</p>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-xs font-bold text-slate-900">Lab Analysis</span>
                  <span class="text-[10px] font-bold text-rose-600">FAILED</span>
                </div>
              </div>
            </div>

            <!-- Findings Groups -->
            <div class="space-y-4">
              <!-- Fraudulent -->
              {findings.fraudulent.map((f) => (
                <div class="investigation-card border-l-4 border-l-rose-500 bg-white">
                  <div class="p-6">
                    <div class="flex items-start justify-between">
                      <div class="flex items-center gap-3">
                        <div class="p-2 bg-rose-50 text-rose-600 rounded">
                          <AlertCircle class="w-5 h-5" />
                        </div>
                        <div>
                          <h4 class="text-sm font-bold text-slate-900">{f.title}</h4>
                          <p class="text-xs text-slate-500 font-medium">{f.file}</p>
                        </div>
                      </div>
                      <div class="text-right">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Confidence</p>
                        <p class="text-sm font-bold text-rose-600">{f.confidence}</p>
                      </div>
                    </div>
                    <div class="mt-4 pl-12">
                      <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Evidence</p>
                      <p class="text-sm text-slate-700 leading-relaxed bg-slate-50 p-3 rounded border border-slate-100 italic">{f.evidence}</p>
                    </div>
                  </div>
                </div>
              ))}

              <!-- Suspicious -->
              {findings.suspicious.map((f) => (
                <div class="investigation-card border-l-4 border-l-amber-500 bg-white">
                  <div class="p-6">
                    <div class="flex items-start justify-between">
                      <div class="flex items-center gap-3">
                        <div class="p-2 bg-amber-50 text-amber-600 rounded">
                          <AlertTriangle class="w-5 h-5" />
                        </div>
                        <div>
                          <h4 class="text-sm font-bold text-slate-900">{f.title}</h4>
                          <p class="text-xs text-slate-500 font-medium">{f.file}</p>
                        </div>
                      </div>
                      <div class="text-right">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Confidence</p>
                        <p class="text-sm font-bold text-amber-600">{f.confidence}</p>
                      </div>
                    </div>
                    <div class="mt-4 pl-12">
                      <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Evidence</p>
                      <p class="text-sm text-slate-700 leading-relaxed bg-slate-50 p-3 rounded border border-slate-100 italic">{f.evidence}</p>
                    </div>
                  </div>
                </div>
              ))}

              <!-- Verified -->
              <div class="investigation-card bg-white opacity-70">
                <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <CheckCircle2 class="w-4 h-4 text-emerald-500" />
                    <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wider">Verified Checks Passed</h4>
                  </div>
                  <button class="text-slate-400 hover:text-slate-600">
                    <MoreVertical class="w-4 h-4" />
                  </button>
                </div>
                <div class="p-4 space-y-2">
                  {findings.verified.map((f) => (
                    <div class="flex items-center gap-3 px-2 py-1">
                      <CheckCircle2 class="w-3.5 h-3.5 text-emerald-500" />
                      <span class="text-xs font-bold text-slate-700">{f.title}</span>
                      <span class="text-[10px] text-slate-400">— {f.evidence}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Document Viewer Placeholder -->
          <div class="investigation-card bg-slate-200 border-slate-300 min-h-[500px] flex flex-col items-center justify-center relative group">
             <div class="absolute inset-0 bg-slate-900/5 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center z-10">
                <button class="btn-primary">
                  <FileSearch class="w-4 h-4" />
                  Open in Forensic Viewer
                </button>
             </div>
             <FileText class="w-16 h-16 text-slate-400" />
             <p class="mt-4 text-slate-500 font-bold uppercase tracking-widest text-xs text-center">Document Preview Container<br/><span class="font-medium normal-case mt-1 block">Full PDF viewer with evidence highlighting will render here</span></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
