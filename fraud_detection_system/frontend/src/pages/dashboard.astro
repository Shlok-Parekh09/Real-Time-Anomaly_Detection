---
import Layout from '../layouts/Layout.astro';
import MetricsCard from '../components/MetricsCard.astro';
import { FileText, CheckCircle, AlertTriangle, ShieldAlert, Plus, ArrowRight, ExternalLink, RefreshCcw, AlertCircle } from "lucide-astro";

---

<Layout title="Dashboard | Anobis" activeTab="dashboard">
  <div class="p-8 max-w-7xl mx-auto space-y-8">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Workspace Overview</h1>
        <p class="text-slate-500 mt-1 font-medium">Monitoring and analysis of financial document integrity.</p>
      </div>
      <a href="/new-investigation" class="btn-primary">
        <Plus class="w-4 h-4" />
        New Investigation
      </a>
    </div>

    <!-- Metrics Grid -->
    <div id="metrics-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <MetricsCard 
        title="Total Processed" 
        value="..." 
        icon={FileText} 
        colorClass="bg-slate-100 text-slate-600"
      />
      <MetricsCard 
        title="Verified" 
        value="..." 
        icon={CheckCircle} 
        colorClass="bg-emerald-100 text-emerald-600"
      />
      <MetricsCard 
        title="Suspicious" 
        value="..." 
        icon={AlertTriangle} 
        colorClass="bg-amber-100 text-amber-600"
      />
      <MetricsCard 
        title="Fraudulent" 
        value="..." 
        icon={ShieldAlert} 
        colorClass="bg-rose-100 text-rose-600"
      />
    </div>

    <!-- Recent Investigations -->
    <div class="investigation-card min-h-[300px] flex flex-col">
      <div class="card-header">
        <h2 class="card-title">Recent Investigations</h2>
        <a href="/investigations" class="text-xs font-semibold text-bank-blue hover:underline flex items-center gap-1">
          View All Investigations
          <ArrowRight class="w-3 h-3" />
        </a>
      </div>
      <div class="overflow-x-auto flex-1">
        <table class="table-standard">
          <thead class="table-header">
            <tr>
              <th class="px-6 py-3">Investigation ID</th>
              <th class="px-6 py-3">Context</th>
              <th class="px-6 py-3">Title</th>
              <th class="px-6 py-3">Date</th>
              <th class="px-6 py-3">Status</th>
              <th class="px-6 py-3 text-right">Actions</th>
            </tr>
          </thead>
          <tbody id="recent-investigations-body" class="table-body">
            <!-- Loading Skeletons -->
            {[1, 2, 3].map(() => (
              <tr class="animate-pulse">
                <td class="px-6 py-4"><div class="h-4 bg-slate-100 rounded w-24"></div></td>
                <td class="px-6 py-4"><div class="h-4 bg-slate-100 rounded w-32"></div></td>
                <td class="px-6 py-4"><div class="h-4 bg-slate-100 rounded w-40"></div></td>
                <td class="px-6 py-4"><div class="h-4 bg-slate-100 rounded w-20"></div></td>
                <td class="px-6 py-4"><div class="h-6 bg-slate-100 rounded-full w-16"></div></td>
                <td class="px-6 py-4 text-right"><div class="h-4 bg-slate-100 rounded w-4 ml-auto"></div></td>
              </tr>
            ))}
          </tbody>
        </table>
        
        <!-- Empty State -->
        <div id="recent-empty-state" class="hidden py-10 flex flex-col items-center justify-center text-center">
          <p class="text-slate-500 text-sm font-medium">No recent investigations found.</p>
        </div>

        <!-- Error State -->
        <div id="recent-error-state" class="hidden py-10 flex flex-col items-center justify-center text-center">
          <p class="text-rose-500 text-sm font-bold flex items-center gap-2">
            <AlertCircle class="w-4 h-4" />
            Failed to load data
          </p>
          <button id="retry-dashboard" class="mt-2 text-xs font-bold text-slate-500 hover:text-slate-900 flex items-center gap-1 mx-auto">
            <RefreshCcw class="w-3 h-3" />
            Try again
          </button>
        </div>
      </div>
    </div>
    
    <!-- Quick Actions / Info -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 investigation-card p-6 bg-slate-900 text-white relative overflow-hidden">
        <div class="relative z-10">
          <h3 class="text-lg font-bold">Internal Audit & Compliance</h3>
          <p class="text-slate-400 mt-2 text-sm max-w-md">Our system automatically monitors cross-document consistency for all loan and mortgage applications to ensure 100% regulatory compliance.</p>
          <div class="mt-6 flex gap-4">
            <button id="quarterly-report-btn" class="px-4 py-2 bg-white text-slate-900 rounded-md font-bold text-sm hover:bg-slate-100 transition-colors">Export Audit Snapshot</button>
            <button id="audit-logs-btn" class="px-4 py-2 bg-slate-800 text-white border border-slate-700 rounded-md font-bold text-sm hover:bg-slate-700 transition-colors">Audit Logs</button>
          </div>
        </div>
        <!-- Decorative abstract shape -->
        <div class="absolute -right-12 -top-12 w-64 h-64 bg-slate-800 rounded-full opacity-50 blur-3xl"></div>
      </div>
      
      <div class="investigation-card p-6 border-slate-200">
        <h3 class="font-bold text-slate-900">System Status</h3>
        <div class="mt-4 space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-500 font-medium">AI Analysis Engine</span>
            <span id="dashboard-ai-status" class="flex items-center text-xs font-bold text-slate-500">
              <span class="w-1.5 h-1.5 bg-slate-400 rounded-full mr-2"></span>
              Checking
            </span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-500 font-medium">Cross-Document Validation</span>
            <span id="dashboard-knn-status" class="flex items-center text-xs font-bold text-slate-500">
              <span class="w-1.5 h-1.5 bg-slate-400 rounded-full mr-2"></span>
              Checking
            </span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-500 font-medium">Metadata Forensic Lab</span>
            <span id="dashboard-ocr-status" class="flex items-center text-xs font-bold text-slate-500">
              <span class="w-1.5 h-1.5 bg-slate-400 rounded-full mr-2"></span>
              Checking
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { api } from '../services/api';
  
  const recentBody = document.getElementById('recent-investigations-body');
  const emptyState = document.getElementById('recent-empty-state');
  const errorState = document.getElementById('recent-error-state');
  const retryBtn = document.getElementById('retry-dashboard');
  const metricsGrid = document.getElementById('metrics-grid');
  let lastInvestigations: any[] = [];

  function setStatus(elId: string, ok: boolean, label: string) {
    const el = document.getElementById(elId);
    if (!el) return;
    el.className = `flex items-center text-xs font-bold ${ok ? 'text-emerald-600' : 'text-rose-600'}`;
    el.innerHTML = `<span class="w-1.5 h-1.5 ${ok ? 'bg-emerald-500' : 'bg-rose-500'} rounded-full mr-2"></span>${label}`;
  }

  async function loadSystemHealth() {
    try {
      const baseUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
      const res = await fetch(`${baseUrl}/api/v1/system/health`).then(r => r.json());
      setStatus('dashboard-ai-status', res.ai === 'ready', res.ai === 'ready' ? 'Gemma Ready' : 'Offline');
      setStatus('dashboard-knn-status', res.knn === 'ready', res.knn === 'ready' ? 'Ready' : 'Offline');
      setStatus('dashboard-ocr-status', res.ocr === 'ready', res.ocr === 'ready' ? 'Ready' : 'Unavailable');
    } catch {
      setStatus('dashboard-ai-status', false, 'Offline');
      setStatus('dashboard-knn-status', false, 'Offline');
      setStatus('dashboard-ocr-status', false, 'Unavailable');
    }
  }

  async function loadDashboardData() {
    if (!recentBody) return;

    // Reset UI
    recentBody.innerHTML = Array(3).fill(0).map(() => `
      <tr class="animate-pulse">
        <td class="px-6 py-4"><div class="h-4 bg-slate-100 rounded w-24"></div></td>
        <td class="px-6 py-4"><div class="h-4 bg-slate-100 rounded w-32"></div></td>
        <td class="px-6 py-4"><div class="h-4 bg-slate-100 rounded w-40"></div></td>
        <td class="px-6 py-4"><div class="h-4 bg-slate-100 rounded w-20"></div></td>
        <td class="px-6 py-4"><div class="h-6 bg-slate-100 rounded-full w-16"></div></td>
        <td class="px-6 py-4 text-right"><div class="h-4 bg-slate-100 rounded w-4 ml-auto"></div></td>
      </tr>
    `).join('');
    emptyState?.classList.add('hidden');
    errorState?.classList.add('hidden');
    recentBody.parentElement?.querySelector('table')?.classList.remove('hidden');

    try {
      const investigations = await api.getInvestigations();
      lastInvestigations = investigations;
      
      // Update Metrics based on calculated Trust Scores
      if (metricsGrid) {
        const total = investigations.length;
        const verified = investigations.filter(i => i.status === 'COMPLETED' && i.trust_score !== null && i.trust_score >= 80).length;
        const suspicious = investigations.filter(i => i.status === 'COMPLETED' && i.trust_score !== null && i.trust_score < 80 && i.trust_score >= 50).length;
        const fraudulent = investigations.filter(i => i.status === 'COMPLETED' && i.trust_score !== null && i.trust_score < 50).length;

        const metricValues = metricsGrid.querySelectorAll('.text-2xl.font-bold');
        if (metricValues[0]) metricValues[0].textContent = total.toString();
        if (metricValues[1]) metricValues[1].textContent = verified.toString();
        if (metricValues[2]) metricValues[2].textContent = suspicious.toString();
        if (metricValues[3]) metricValues[3].textContent = fraudulent.toString();
      }

      // Render Recent (top 5)
      const recent = investigations.slice(0, 5);
      
      if (recent.length === 0) {
        recentBody.parentElement?.querySelector('table')?.classList.add('hidden');
        emptyState?.classList.remove('hidden');
        return;
      }

      recentBody.innerHTML = recent.map(inv => {
        const date = new Date(inv.created_at).toLocaleDateString('en-US', {
          month: 'short',
          day: 'numeric'
        });

        let statusClass = 'bg-slate-50 text-slate-700 border-slate-200';
        if (inv.status === 'COMPLETED') statusClass = 'bg-emerald-50 text-emerald-700 border-emerald-200';
        if (inv.status === 'PROCESSING') statusClass = 'bg-blue-50 text-blue-700 border-blue-200';
        if (inv.status === 'FAILED') statusClass = 'bg-rose-50 text-rose-700 border-rose-200';
        if (inv.status === 'PENDING') statusClass = 'bg-amber-50 text-amber-700 border-amber-200';

        return `
          <tr class="hover:bg-slate-50 transition-colors group">
            <td class="px-6 py-4">
              <span class="font-mono text-xs font-semibold text-slate-900 bg-slate-100 px-2 py-1 rounded">${inv.id.substring(0, 8)}...</span>
            </td>
            <td class="px-6 py-4">
              <p class="text-sm font-medium text-slate-700">${inv.context}</p>
            </td>
            <td class="px-6 py-4">
              <p class="text-sm font-semibold text-slate-900">${inv.title || 'Untitled'}</p>
            </td>
            <td class="px-6 py-4">
              <p class="text-sm text-slate-500 font-medium">${date}</p>
            </td>
            <td class="px-6 py-4">
               <span class="px-2 py-0.5 rounded-full text-[10px] font-bold border ${statusClass}">
                ${inv.status}
               </span>
            </td>
            <td class="px-6 py-4 text-right">
              <a href="/investigate/?id=${inv.id}" class="text-slate-400 hover:text-bank-blue transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link ml-auto"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
              </a>
            </td>
          </tr>
        `;
      }).join('');

    } catch (error) {
      console.error('Dashboard load failed:', error);
      recentBody.parentElement?.querySelector('table')?.classList.add('hidden');
      errorState?.classList.remove('hidden');
    }
  }

  retryBtn?.addEventListener('click', loadDashboardData);
  
  document.getElementById('quarterly-report-btn')?.addEventListener('click', () => {
    if (lastInvestigations.length === 0) {
      alert('No investigations available to export.');
      return;
    }
    const completed = lastInvestigations.filter(i => i.status === 'COMPLETED');
    const snapshot = {
      generated_at: new Date().toISOString(),
      total_investigations: lastInvestigations.length,
      completed: completed.length,
      auto_approved: completed.filter(i => i.recommendation === 'AUTO_APPROVE').length,
      manual_review: completed.filter(i => i.recommendation !== 'AUTO_APPROVE').length,
      investigations: lastInvestigations.map(i => ({
        id: i.id,
        title: i.title,
        context: i.context,
        status: i.status,
        trust_score: i.trust_score,
        confidence_score: i.confidence_score,
        recommendation: i.recommendation,
      })),
    };
    const blob = new Blob([JSON.stringify(snapshot, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `Anobis_Audit_Snapshot_${new Date().toISOString().slice(0, 10)}.json`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
  });
  document.getElementById('audit-logs-btn')?.addEventListener('click', () => {
    window.location.href = '/investigations';
  });

  loadDashboardData();
  loadSystemHealth();
</script>
