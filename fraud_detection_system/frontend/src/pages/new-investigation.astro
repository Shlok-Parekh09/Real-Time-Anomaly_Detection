---
import Layout from '../layouts/Layout.astro';
import { ShieldCheck, Upload, ChevronRight, File, X, Sparkles, Building2, UserCheck, Landmark, Receipt, FileSearch, Loader2, AlertCircle, CheckCircle2 } from "lucide-astro";

const contexts = [
  { id: 'Loan Approval', name: 'Loan Approval', description: 'Personal or business loan verification', icon: Landmark },
  { id: 'Mortgage Underwriting', name: 'Mortgage Underwriting', description: 'Property loan document analysis', icon: Building2 },
  { id: 'Tenant Screening', name: 'Tenant Screening', description: 'Rental application verification', icon: UserCheck },
  { id: 'KYC / Onboarding', name: 'KYC / Onboarding', description: 'Identity and address verification', icon: ShieldCheck },
  { id: 'Insurance Claims', name: 'Insurance Claims', description: 'Claim document authenticity check', icon: Receipt },
  { id: 'Internal Audit', name: 'Internal Audit', description: 'Corporate compliance review', icon: FileSearch },
];
---

<Layout title="New Investigation | Anobis" activeTab="investigations">
  <div class="max-w-4xl mx-auto p-8 space-y-8">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-xs font-semibold text-slate-500 uppercase tracking-widest">
      <a href="/" class="hover:text-bank-blue transition-colors">Dashboard</a>
      <ChevronRight class="w-3 h-3" />
      <span class="text-slate-900">New Investigation</span>
    </nav>

    <div id="header-section">
      <h1 class="text-2xl font-bold text-slate-900">Create New Investigation</h1>
      <p class="text-slate-500 mt-1 font-medium">Select context and upload documents for forensic analysis.</p>
    </div>

    <!-- Step 1: Context Selection -->
    <div id="step-1" class="space-y-8">
      <section class="space-y-4">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-wider">1. Investigation Context</h2>
          <div class="flex items-center gap-2 px-3 py-1 bg-violet-50 text-violet-700 rounded-full border border-violet-100 cursor-pointer hover:bg-violet-100 transition-colors">
            <Sparkles class="w-3 h-3" />
            <span class="text-[10px] font-bold uppercase tracking-widest">Automatic Detection</span>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {contexts.map((ctx) => (
            <label class="group relative flex items-start gap-4 p-4 bg-white border border-slate-200 rounded-lg cursor-pointer hover:border-bank-blue hover:shadow-sm transition-all has-[:checked]:border-bank-blue has-[:checked]:bg-blue-50/30 has-[:checked]:ring-1 has-[:checked]:ring-bank-blue">
              <input type="radio" name="context" value={ctx.id} class="sr-only" />
              <div class="p-2 rounded-md bg-slate-100 text-slate-600 group-hover:bg-blue-100 group-hover:text-bank-blue transition-colors">
                <ctx.icon class="w-5 h-5" />
              </div>
              <div>
                <p class="text-sm font-bold text-slate-900">{ctx.name}</p>
                <p class="text-xs text-slate-500 mt-1 leading-relaxed">{ctx.description}</p>
              </div>
            </label>
          ))}
        </div>
      </section>

      <section class="space-y-4">
         <h2 class="text-sm font-bold text-slate-900 uppercase tracking-wider">2. Investigation Title (Optional)</h2>
         <input type="text" id="investigation-title" placeholder="e.g. Q2 Mortgage Audit - Rajesh Kumar" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-lg text-sm focus:ring-1 focus:ring-bank-blue outline-none transition-all" />
      </section>

      <div class="pt-6 border-t border-slate-200 flex items-center justify-end gap-4">
        <button id="cancel-btn" class="px-6 py-2.5 text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors">Cancel</button>
        <button id="create-inv-btn" class="btn-primary px-8 py-2.5">
          Continue to Upload
          <Loader2 id="create-loader" class="w-4 h-4 animate-spin hidden" />
        </button>
      </div>
    </div>

    <!-- Step 2: Upload (Hidden by default) -->
    <div id="step-2" class="space-y-8 hidden">
       <section class="space-y-4">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-bold text-slate-900 uppercase tracking-wider">3. Upload Documents</h2>
          <span id="inv-id-badge" class="px-3 py-1 bg-slate-100 text-slate-600 rounded-full border border-slate-200 text-[10px] font-bold uppercase tracking-widest">ID: ...</span>
        </div>
        
        <div id="drop-zone" class="bg-white border-2 border-dashed border-slate-200 rounded-xl p-12 flex flex-col items-center justify-center gap-4 hover:border-bank-blue hover:bg-slate-50/50 transition-all cursor-pointer group relative">
          <input type="file" id="file-input" multiple accept=".pdf,.png,.jpg,.jpeg" class="absolute inset-0 opacity-0 cursor-pointer" />
          <div class="p-4 rounded-full bg-slate-100 text-slate-400 group-hover:bg-blue-100 group-hover:text-bank-blue transition-all">
            <Upload class="w-8 h-8" />
          </div>
          <div class="text-center">
            <p class="text-slate-900 font-bold">Drag and drop files here</p>
            <p class="text-slate-500 text-sm mt-1 font-medium">Support for PDF, JPG, PNG (Max 20MB per file)</p>
          </div>
          <button class="btn-secondary mt-2 pointer-events-none">Browse Files</button>
        </div>

        <!-- File List -->
        <div id="file-list" class="space-y-3">
          <!-- Dynamically populated -->
        </div>
      </section>

      <div class="pt-6 border-t border-slate-200 flex items-center justify-between">
        <button id="back-to-step-1" class="px-6 py-2.5 text-sm font-bold text-slate-500 hover:text-slate-900 transition-colors">Back</button>
        <button id="start-analysis-btn" class="btn-primary px-8 py-2.5 opacity-50 pointer-events-none">
          Start Forensic Analysis
          <Loader2 id="analysis-loader" class="w-4 h-4 animate-spin hidden" />
        </button>
      </div>
    </div>

    <!-- Error Toast -->
    <div id="error-toast" class="fixed bottom-8 right-8 bg-rose-50 border border-rose-200 p-4 rounded-lg shadow-lg flex items-start gap-3 max-w-md transform translate-y-24 transition-transform duration-300 z-50">
       <AlertCircle class="w-5 h-5 text-rose-500 flex-shrink-0" />
       <div>
         <p class="text-sm font-bold text-rose-900">Action Failed</p>
         <p id="error-toast-msg" class="text-xs text-rose-700 mt-1">An unexpected error occurred.</p>
       </div>
       <button id="close-error" class="text-rose-400 hover:text-rose-600 ml-auto">
         <X class="w-4 h-4" />
       </button>
    </div>
  </div>
</Layout>

<script>
  import { api } from '../services/api';
  
  // State
  let currentInvestigationId: string | null = null;
  let selectedFiles: File[] = [];

  // Elements
  const step1 = document.getElementById('step-1');
  const step2 = document.getElementById('step-2');
  const createInvBtn = document.getElementById('create-inv-btn');
  const createLoader = document.getElementById('create-loader');
  const titleInput = document.getElementById('investigation-title') as HTMLInputElement;
  const invIdBadge = document.getElementById('inv-id-badge');
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const fileList = document.getElementById('file-list');
  const startAnalysisBtn = document.getElementById('start-analysis-btn');
  const analysisLoader = document.getElementById('analysis-loader');
  const errorToast = document.getElementById('error-toast');
  const errorToastMsg = document.getElementById('error-toast-msg');
  const closeError = document.getElementById('close-error');

  function showError(msg: string) {
    if (errorToast && errorToastMsg) {
      errorToastMsg.textContent = msg;
      errorToast.classList.remove('translate-y-24');
    }
  }

  closeError?.addEventListener('click', () => {
    errorToast?.classList.add('translate-y-24');
  });

  // Step 1 -> Step 2
  createInvBtn?.addEventListener('click', async () => {
    const contextInput = document.querySelector('input[name="context"]:checked') as HTMLInputElement;
    if (!contextInput) {
      showError('Please select an investigation context.');
      return;
    }

    createInvBtn.classList.add('opacity-70', 'pointer-events-none');
    createLoader?.classList.remove('hidden');

    try {
      const inv = await api.createInvestigation({
        context: contextInput.value,
        title: titleInput.value || undefined
      });

      currentInvestigationId = inv.id;
      if (invIdBadge) invIdBadge.textContent = `ID: ${inv.id.substring(0, 8)}...`;
      
      step1?.classList.add('hidden');
      step2?.classList.remove('hidden');
      window.scrollTo(0, 0);
    } catch (error) {
      console.error('Failed to create investigation:', error);
      showError(error instanceof Error ? error.message : 'Failed to create investigation');
    } finally {
      createInvBtn.classList.remove('opacity-70', 'pointer-events-none');
      createLoader?.classList.add('hidden');
    }
  });

  // File Handling
  fileInput?.addEventListener('change', (e) => {
    const files = Array.from(fileInput.files || []);
    addFiles(files);
  });

  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-bank-blue', 'bg-blue-50/50');
  });

  dropZone?.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-bank-blue', 'bg-blue-50/50');
  });

  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-bank-blue', 'bg-blue-50/50');
    const files = Array.from(e.dataTransfer?.files || []);
    addFiles(files);
  });

  function addFiles(files: File[]) {
    const validTypes = ['application/pdf', 'image/png', 'image/jpeg', 'image/jpg'];
    const filtered = files.filter(f => {
      if (!validTypes.includes(f.type)) {
        showError(`File ${f.name} is not a supported format.`);
        return false;
      }
      if (f.size > 20 * 1024 * 1024) {
        showError(`File ${f.name} exceeds 20MB limit.`);
        return false;
      }
      return true;
    });

    selectedFiles = [...selectedFiles, ...filtered];
    renderFileList();
    updateAnalysisBtn();
  }

  function renderFileList() {
    if (!fileList) return;
    fileList.innerHTML = selectedFiles.map((file, index) => `
      <div class="flex items-center justify-between p-3 bg-white border border-slate-200 rounded-lg group">
        <div class="flex items-center gap-3">
          <div class="p-2 bg-slate-100 text-slate-500 rounded">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
          </div>
          <div>
            <p class="text-sm font-bold text-slate-900">${file.name}</p>
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">${(file.size / (1024 * 1024)).toFixed(2)} MB</p>
          </div>
        </div>
        <button onclick="window.removeFile(${index})" class="p-1.5 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded transition-all opacity-0 group-hover:opacity-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
    `).join('');
  }

  // Exposed for inline onclick
  (window as any).removeFile = (index: number) => {
    selectedFiles.splice(index, 1);
    renderFileList();
    updateAnalysisBtn();
  };

  function updateAnalysisBtn() {
    if (selectedFiles.length > 0) {
      startAnalysisBtn?.classList.remove('opacity-50', 'pointer-events-none');
    } else {
      startAnalysisBtn?.classList.add('opacity-50', 'pointer-events-none');
    }
  }

  // Final Action
  startAnalysisBtn?.addEventListener('click', async () => {
    if (!currentInvestigationId || selectedFiles.length === 0) return;

    startAnalysisBtn.classList.add('opacity-70', 'pointer-events-none');
    analysisLoader?.classList.remove('hidden');

    try {
      // 1. Upload Documents
      await api.uploadDocuments(currentInvestigationId, selectedFiles);
      
      // 2. Start Analysis
      await api.analyzeInvestigation(currentInvestigationId);

      // 3. Redirect to Investigation Page
      window.location.href = `/investigate/${currentInvestigationId}`;
    } catch (error) {
      console.error('Failed to complete setup:', error);
      showError(error instanceof Error ? error.message : 'Failed to upload or analyze documents');
      startAnalysisBtn.classList.remove('opacity-70', 'pointer-events-none');
      analysisLoader?.classList.add('hidden');
    }
  });

  document.getElementById('back-to-step-1')?.addEventListener('click', () => {
    step2?.classList.add('hidden');
    step1?.classList.remove('hidden');
  });

  document.getElementById('cancel-btn')?.addEventListener('click', () => {
    window.location.href = '/investigations';
  });
</script>
