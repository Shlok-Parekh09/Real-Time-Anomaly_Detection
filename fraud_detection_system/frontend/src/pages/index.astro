---
import { Menu, X, Play } from "lucide-astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>Anobis | Enterprise Forensics & Tampering Lab</title>
    <style>
      /* Global configurations */
      body {
        font-family: 'Inter', sans-serif;
        background-color: black;
        color: white;
        margin: 0;
        overflow: hidden;
      }
      
      /* Liquid Glass styling */
      .liquid-glass {
        background: rgba(255, 255, 255, 0.01);
        background-blend-mode: luminosity;
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        border: none;
        box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1);
        position: relative;
        overflow: hidden;
      }
      
      .liquid-glass::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1.4px;
        background: linear-gradient(180deg, rgba(255,255,255,0.45) 0%, rgba(255,255,255,0.15) 20%, rgba(255,255,255,0) 40%, rgba(255,255,255,0) 60%, rgba(255,255,255,0.15) 80%, rgba(255,255,255,0.45) 100%);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
      }

      /* Animation Blur Fade Up */
      @keyframes blurFadeUp {
        from {
          opacity: 0;
          filter: blur(20px);
          transform: translateY(40px);
        }
        to {
          opacity: 1;
          filter: blur(0);
          transform: translateY(0);
        }
      }
      
      .animate-blur-fade-up {
        opacity: 0;
        animation: blurFadeUp 1s ease-out forwards;
      }
      
      /* Mobile dropdown link transition properties */
      .mobile-link {
        transform: translateX(-16px);
        opacity: 0;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }
      
      .mobile-menu-open .mobile-link {
        transform: translateX(0);
        opacity: 1;
      }

      /* Full viewport container */
      .full-viewport-hero {
        position: relative;
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      @keyframes cloudDrift {
        0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
        50% { transform: translate3d(4vw, -3vh, 0) scale(1.08); }
      }

      .offline-cloud {
        position: fixed;
        border-radius: 9999px;
        filter: blur(100px);
        opacity: 0.72;
        pointer-events: none;
        animation: cloudDrift 16s ease-in-out infinite;
      }
    </style>
  </head>
  <body class="bg-black select-none">
    
    <!-- Offline cloudy blue/orange background -->
    <div class="fixed inset-0 z-0 bg-[radial-gradient(circle_at_20%_20%,#1d4ed8_0%,transparent_34%),radial-gradient(circle_at_82%_75%,#f97316_0%,transparent_32%),linear-gradient(135deg,#020617_0%,#0f172a_55%,#111827_100%)]"></div>
    <div class="offline-cloud z-[1] -left-[10vw] top-[12vh] w-[55vw] h-[55vh] bg-blue-700/70"></div>
    <div class="offline-cloud z-[1] right-[-12vw] bottom-[4vh] w-[50vw] h-[45vh] bg-orange-500/55" style="animation-delay: -6s;"></div>
    <div class="offline-cloud z-[1] left-[36vw] bottom-[20vh] w-[35vw] h-[35vh] bg-cyan-500/25" style="animation-delay: -10s;"></div>
    
    <!-- Blue Tint Overlay (tints the warm orange background video to Banking Blue) -->
    <div 
      class="fixed inset-0 z-5 pointer-events-none bg-gradient-to-tr from-[#1E3A8A]/45 via-blue-950/25 to-black/20 mix-blend-color"
    ></div>
    
    <!-- Bottom Blur Overlay Mask -->
    <div 
      class="fixed inset-0 z-10 pointer-events-none backdrop-blur-xl" 
      style="
        -webkit-mask-image: linear-gradient(to top, black 0%, transparent 45%);
        mask-image: linear-gradient(to top, black 0%, transparent 45%);
      "
    ></div>

    <!-- Cinematic Hero Grid Layout -->
    <div class="full-viewport-hero z-20 relative">
      
      <!-- NAVBAR -->
      <nav class="relative z-50 flex items-center justify-between px-4 sm:px-6 md:px-12 py-4 md:py-6 bg-transparent">
        
        <!-- Left: Text Logo Brand -->
        <a href="/" class="flex items-center gap-2 h-8 md:h-10 animate-blur-fade-up" style="animation-delay: 0ms;">
          <span class="font-extrabold text-white text-lg tracking-widest uppercase">Anobis</span>
          <span class="px-2 py-0.5 rounded bg-blue-600 text-white text-[9px] font-black uppercase tracking-widest">Forensics</span>
        </a>

        <!-- Right: Investigate Cases pill (subtle, outlined) -->
        <div class="flex items-center gap-4">
          <a href="/dashboard" class="hidden lg:inline-flex items-center justify-center px-4 py-2 border border-white/20 bg-white/10 hover:bg-white text-white hover:text-black text-xs font-semibold rounded-full transition-all duration-300 hover:shadow-[0_0_15px_rgba(59,130,246,0.3)] animate-blur-fade-up cursor-pointer" style="animation-delay: 200ms;">
            Launch Console
          </a>
          
          <!-- Hamburger Button (Mobile Only) -->
          <button id="hamburger-btn" class="flex lg:hidden items-center justify-center w-10 h-10 rounded-full liquid-glass hover:bg-blue-950/20 hover:text-blue-300 transition-all animate-blur-fade-up focus:outline-none cursor-pointer" style="animation-delay: 350ms;">
            <div class="relative w-6 h-6 flex items-center justify-center">
              <Menu id="menu-icon" class="w-5 h-5 text-white transition-all duration-500 ease-out" />
              <X id="close-icon" class="absolute w-5 h-5 text-white transition-all duration-500 ease-out scale-50 opacity-0 rotate-180" />
            </div>
          </button>
        </div>
      </nav>

      <!-- MOBILE MENU DROPDOWN -->
      <div id="mobile-menu" class="absolute top-[72px] left-0 right-0 z-40 flex flex-col p-4 bg-gray-900/95 backdrop-blur-lg border-t border-b border-gray-800 shadow-2xl transition-all duration-500 ease-out -translate-y-4 opacity-0 pointer-events-none">
        <div class="flex flex-col gap-2">
          <a href="/dashboard" class="mobile-link py-3 px-3 rounded-lg hover:bg-gray-800/50 text-sm font-semibold transition-all text-white/95" style="transition-delay: 50ms;">Launch Console</a>
        </div>
      </div>

      <!-- HERO CONTENT -->
      <div class="relative z-30 flex-1 flex flex-col justify-end px-4 sm:px-6 md:px-12 pb-8 md:pb-16 bg-transparent">
        <div class="flex flex-col md:flex-row items-end justify-between gap-8">
          
          <!-- Left side Content Block -->
          <div class="flex-1 max-w-3xl space-y-4">
            
            <!-- Metadata Badges -->
            <div class="flex flex-wrap items-center gap-3 sm:gap-6 mb-6 md:mb-8 text-xs sm:text-sm font-semibold text-white/95 animate-blur-fade-up" style="animation-delay: 300ms;">
              <div class="flex items-center gap-1.5">
                <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                <span>Local AI Engine</span>
              </div>
              <span class="w-1.5 h-1.5 bg-white/30 rounded-full"></span>
              <div class="flex items-center gap-1.5">
                <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
                <span>Offline Processing</span>
              </div>
            </div>

            <!-- Title Header -->
            <h1 class="text-3xl sm:text-5xl md:text-6xl lg:text-7xl font-normal tracking-tight text-white mb-4 md:mb-6 leading-none animate-blur-fade-up" style="letter-spacing: -0.04em; animation-delay: 400ms;">
              AI Forensic Investigation<br class="hidden sm:inline"/> & Document Fraud Orchestrator
            </h1>

            <!-- Description -->
            <p class="text-base sm:text-lg md:text-xl text-gray-400 mb-6 md:mb-12 max-w-2xl leading-relaxed animate-blur-fade-up" style="animation-delay: 500ms;">
              An offline-first AI investigation orchestrator for forensic document analysis, cross-document verification, and fraud detection.
            </p>

            <!-- CTA Actions Buttons Row -->
            <div class="flex flex-wrap items-center gap-3 sm:gap-4 pt-4">
              <a href="/dashboard" class="flex items-center gap-2 rounded-full px-6 sm:px-8 py-2.5 sm:py-3 bg-white text-black text-sm font-semibold shadow-lg hover:bg-blue-50 hover:text-blue-900 hover:shadow-[0_0_20px_rgba(59,130,246,0.4)] transition-all cursor-pointer animate-blur-fade-up" style="animation-delay: 600ms;">
                <Play class="w-[18px] h-[18px] fill-black text-black" />
                Investigate Cases
              </a>
            </div>

          </div>

          <!-- Empty Right side to keep left content formatted -->
          <div class="flex items-center gap-3 self-start md:self-auto"></div>

        </div>
      </div>

      <!-- MINIMAL FOOTER -->
      <footer class="relative z-30 py-6 border-t border-white/5 text-center text-[10px] font-bold text-white/40 uppercase tracking-widest bg-transparent flex-shrink-0">
        &copy; 2026 Anobis Forensic Lab. All rights reserved. Offline Sandbox.
      </footer>

    </div>

    <!-- Mobile Drawer Interactivity JavaScript -->
    <script>
      import { api } from '../services/api';
      document.addEventListener('astro:page-load', () => {
      const hamburgerBtn = document.getElementById('hamburger-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      hamburgerBtn?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('translate-y-0');
        if (isOpen) {
          // Close Drawer
          mobileMenu?.classList.remove('translate-y-0', 'opacity-100', 'mobile-menu-open');
          mobileMenu?.classList.add('-translate-y-4', 'opacity-0', 'pointer-events-none');
          // Icon rotation & transitions
          menuIcon?.classList.remove('scale-50', 'opacity-0', 'rotate-180');
          closeIcon?.classList.add('scale-50', 'opacity-0', 'rotate-180');
        } else {
          // Open Drawer
          mobileMenu?.classList.add('translate-y-0', 'opacity-100', 'mobile-menu-open');
          mobileMenu?.classList.remove('-translate-y-4', 'opacity-0', 'pointer-events-none');
          // Icon rotation & transitions
          menuIcon?.classList.add('scale-50', 'opacity-0', 'rotate-180');
          closeIcon?.classList.remove('scale-50', 'opacity-0', 'rotate-180');
        }
      });
      // Early warmup for local Gemma reasoning
      api.warmupLlm().catch(err => console.warn('LLM Warmup skipped/failed:', err));
      });
</script>

  </body>
</html>
