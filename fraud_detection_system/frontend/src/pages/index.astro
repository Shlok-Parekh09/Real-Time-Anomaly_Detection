---
import { Search, User, Menu, X, Play, ChevronLeft, ChevronRight, Star, Clock, Calendar } from "lucide-astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>Anobis | Enterprise Forensics & Tampering Lab</title>
    <style>
      /* Global configurations */
      body {
        font-family: 'Inter', sans-serif;
        background-color: black;
        color: white;
        margin: 0;
        overflow: hidden;
      }
      
      /* Liquid Glass styling */
      .liquid-glass {
        background: rgba(255, 255, 255, 0.01);
        background-blend-mode: luminosity;
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        border: none;
        box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1);
        position: relative;
        overflow: hidden;
      }
      
      .liquid-glass::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1.4px;
        background: linear-gradient(180deg, rgba(255,255,255,0.45) 0%, rgba(255,255,255,0.15) 20%, rgba(255,255,255,0) 40%, rgba(255,255,255,0) 60%, rgba(255,255,255,0.15) 80%, rgba(255,255,255,0.45) 100%);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
      }

      /* Animation Blur Fade Up */
      @keyframes blurFadeUp {
        from {
          opacity: 0;
          filter: blur(20px);
          transform: translateY(40px);
        }
        to {
          opacity: 1;
          filter: blur(0);
          transform: translateY(0);
        }
      }
      
      .animate-blur-fade-up {
        opacity: 0;
        animation: blurFadeUp 1s ease-out forwards;
      }

      /* Mobile dropdown link transition properties */
      .mobile-link {
        transform: translateX(-16px);
        opacity: 0;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }
      
      .mobile-menu-open .mobile-link {
        transform: translateX(0);
        opacity: 1;
      }

      /* Full viewport container */
      .full-viewport-hero {
        position: relative;
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }
    </style>
  </head>
  <body class="bg-black select-none">
    
    <!-- Background Cinematic Loop Video -->
    <video 
      src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260406_094145_4a271a6c-3869-4f1c-8aa7-aeb0cb227994.mp4" 
      autoplay 
      loop 
      muted 
      playsinline 
      class="fixed inset-0 w-full h-full object-cover z-0 pointer-events-none"
    ></video>
    
    <!-- Blue Tint Overlay (tints the warm orange background video to Banking Blue) -->
    <div 
      class="fixed inset-0 z-5 pointer-events-none bg-gradient-to-tr from-[#1E3A8A]/45 via-blue-950/25 to-black/20 mix-blend-color"
    ></div>
    
    <!-- Bottom Blur Overlay Mask -->
    <div 
      class="fixed inset-0 z-10 pointer-events-none backdrop-blur-xl" 
      style="
        -webkit-mask-image: linear-gradient(to top, black 0%, transparent 45%);
        mask-image: linear-gradient(to top, black 0%, transparent 45%);
      "
    ></div>

    <!-- Cinematic Hero Section Grid Layout -->
    <div class="full-viewport-hero z-20 relative">
      
      <!-- NAVBAR -->
      <nav class="relative z-50 flex items-center justify-between px-4 sm:px-6 md:px-12 py-4 md:py-6 bg-transparent">
        
        <!-- Left: Text Logo Brand -->
        <a href="/" class="flex items-center gap-2 h-8 md:h-10 animate-blur-fade-up" style="animation-delay: 0ms;">
          <span class="font-extrabold text-white text-lg tracking-widest uppercase">Anobis</span>
          <span class="px-2 py-0.5 rounded bg-blue-600 text-white text-[9px] font-black uppercase tracking-widest">Forensics</span>
        </a>

        <!-- Center: Nav links (Hidden below lg breakpoint) -->
        <div class="hidden lg:flex items-center gap-8">
          <a href="/dashboard" class="text-sm font-semibold text-white/80 hover:text-blue-400 transition-colors animate-blur-fade-up" style="animation-delay: 100ms;">Workspace Overview</a>
          <a href="/investigations" class="text-sm font-semibold text-white/80 hover:text-blue-400 transition-colors animate-blur-fade-up" style="animation-delay: 150ms;">Forensics Lab</a>
          <a href="/investigations" class="text-sm font-semibold text-white/80 hover:text-blue-400 transition-colors animate-blur-fade-up" style="animation-delay: 200ms;">Cross-Doc Engine</a>
          <a href="/dashboard" class="text-sm font-semibold text-white/80 hover:text-blue-400 transition-colors animate-blur-fade-up" style="animation-delay: 250ms;">Scoring Engine</a>
          <a href="/investigations" class="text-sm font-semibold text-white/80 hover:text-blue-400 transition-colors animate-blur-fade-up" style="animation-delay: 300ms;">Timeline Log</a>
        </div>

        <!-- Right Buttons (Search, Profile, Burger) -->
        <div class="flex items-center gap-4">
          <!-- Search Pill -->
          <a href="/investigations" class="hidden sm:flex items-center gap-2 rounded-full px-4 md:px-6 py-2 liquid-glass text-sm font-medium hover:bg-blue-950/20 hover:text-blue-300 transition-all animate-blur-fade-up cursor-pointer" style="animation-delay: 350ms;">
            <Search class="w-[18px] h-[18px] text-white" />
            Search
          </a>

          <!-- Profile Circle -->
          <a href="/dashboard" class="hidden sm:flex items-center justify-center w-10 h-10 rounded-full liquid-glass hover:bg-blue-950/20 hover:text-blue-300 transition-all animate-blur-fade-up cursor-pointer" style="animation-delay: 400ms;">
            <User class="w-[18px] h-[18px] text-white" />
          </a>

          <!-- Hamburger Button (Mobile Only) -->
          <button id="hamburger-btn" class="flex lg:hidden items-center justify-center w-10 h-10 rounded-full liquid-glass hover:bg-blue-950/20 hover:text-blue-300 transition-all animate-blur-fade-up focus:outline-none cursor-pointer" style="animation-delay: 350ms;">
            <div class="relative w-6 h-6 flex items-center justify-center">
              <!-- Menu Icon -->
              <Menu id="menu-icon" class="w-5 h-5 text-white transition-all duration-500 ease-out" />
              <!-- Close X Icon -->
              <X id="close-icon" class="absolute w-5 h-5 text-white transition-all duration-500 ease-out scale-50 opacity-0 rotate-180" />
            </div>
          </button>
        </div>
      </nav>

      <!-- MOBILE MENU DROPDOWN (below lg breakpoint) -->
      <div id="mobile-menu" class="absolute top-[72px] left-0 right-0 z-40 flex flex-col p-4 bg-gray-900/95 backdrop-blur-lg border-t border-b border-gray-800 shadow-2xl transition-all duration-500 ease-out -translate-y-4 opacity-0 pointer-events-none">
        <div class="flex flex-col gap-2">
          <a href="/dashboard" class="mobile-link py-3 px-3 rounded-lg hover:bg-gray-800/50 text-sm font-semibold transition-all text-white/95" style="transition-delay: 50ms;">Workspace Overview</a>
          <a href="/investigations" class="mobile-link py-3 px-3 rounded-lg hover:bg-gray-800/50 text-sm font-semibold transition-all text-white/95" style="transition-delay: 100ms;">Forensics Lab</a>
          <a href="/investigations" class="mobile-link py-3 px-3 rounded-lg hover:bg-gray-800/50 text-sm font-semibold transition-all text-white/95" style="transition-delay: 150ms;">Cross-Doc Engine</a>
          <a href="/dashboard" class="mobile-link py-3 px-3 rounded-lg hover:bg-gray-800/50 text-sm font-semibold transition-all text-white/95" style="transition-delay: 200ms;">Scoring Engine</a>
          <a href="/investigations" class="mobile-link py-3 px-3 rounded-lg hover:bg-gray-800/50 text-sm font-semibold transition-all text-white/95" style="transition-delay: 250ms;">Timeline Log</a>
        </div>
        <div class="flex sm:hidden items-center justify-between border-t border-gray-800 mt-4 pt-4 px-2">
          <a href="/investigations" class="flex items-center gap-2 rounded-full px-5 py-2 liquid-glass text-xs font-semibold hover:bg-blue-950/20 hover:text-blue-300 transition-all text-white">
            <Search class="w-[14px] h-[14px] text-white" />
            Search
          </a>
          <a href="/dashboard" class="flex items-center justify-center w-9 h-9 rounded-full liquid-glass hover:bg-blue-950/20 hover:text-blue-300 transition-all text-white">
            <User class="w-4 h-4 text-white" />
          </a>
        </div>
      </div>

      <!-- HERO CONTENT (Bottom viewport layout) -->
      <div class="relative z-30 flex-1 flex flex-col justify-end px-4 sm:px-6 md:px-12 pb-8 md:pb-16 bg-transparent">
        <div class="flex flex-col md:flex-row items-end justify-between gap-8">
          
          <!-- Left side Content Block -->
          <div class="flex-1 max-w-3xl space-y-4">
            
            <!-- Metadata Row -->
            <div class="flex flex-wrap items-center gap-3 sm:gap-6 mb-6 md:mb-8 text-xs sm:text-sm font-medium text-white/90 animate-blur-fade-up" style="animation-delay: 300ms;">
              <!-- Accuracy Metric -->
              <div class="flex items-center gap-1.5">
                <Star class="w-4 h-4 sm:w-5 sm:h-5 fill-blue-400 text-blue-400" />
                <span>9.8/10 Trust Rating</span>
              </div>
              <span class="w-1 h-1 bg-white/40 rounded-full"></span>
              <!-- Pipeline Duration -->
              <div class="flex items-center gap-1.5">
                <Clock class="w-4 h-4 text-blue-400" />
                <span>Real-Time Pipeline</span>
              </div>
              <span class="w-1 h-1 bg-white/40 rounded-full"></span>
              <!-- Calendar/Local Status -->
              <div class="flex items-center gap-1.5">
                <Calendar class="w-4 h-4 text-blue-400" />
                <span>Local First Engine</span>
              </div>
            </div>

            <!-- Title Header -->
            <h1 class="text-3xl sm:text-5xl md:text-6xl lg:text-7xl font-normal tracking-tight text-white mb-4 md:mb-6 leading-none animate-blur-fade-up" style="letter-spacing: -0.04em; animation-delay: 400ms;">
              Step Through.<br class="hidden sm:inline"/> Work Smarter.
            </h1>

            <!-- Description -->
            <p class="text-base sm:text-lg md:text-xl text-gray-400 mb-6 md:mb-12 max-w-2xl leading-relaxed animate-blur-fade-up" style="animation-delay: 500ms;">
              An enterprise-grade document fraud and forensic platform. Correlate identity, transaction math, and pixel compression signatures locally with zero cloud dependencies.
            </p>

            <!-- CTA Actions Buttons Row -->
            <div class="flex flex-wrap items-center gap-3 sm:gap-4 pt-4">
              <!-- Play / Investigate CTA -->
              <a href="/dashboard" class="flex items-center gap-2 rounded-full px-6 sm:px-8 py-2.5 sm:py-3 bg-white text-black text-sm font-semibold shadow-lg hover:bg-blue-50 hover:text-blue-900 hover:shadow-[0_0_20px_rgba(59,130,246,0.4)] transition-all cursor-pointer animate-blur-fade-up" style="animation-delay: 600ms;">
                <Play class="w-[18px] h-[18px] fill-black text-black" />
                Investigate
              </a>
              <!-- Learn More -->
              <a href="/investigations" class="rounded-full px-6 sm:px-8 py-2.5 sm:py-3 liquid-glass text-white text-sm font-semibold hover:bg-blue-950/20 hover:text-blue-300 transition-all cursor-pointer animate-blur-fade-up" style="animation-delay: 700ms;">
                Learn More
              </a>
            </div>

          </div>

          <!-- Right side: Quick Case Nav arrows -->
          <div class="flex items-center gap-3 self-start md:self-auto">
            <!-- Previous case arrow -->
            <a href="/investigations" class="flex items-center justify-center rounded-full px-4 sm:px-6 py-2.5 sm:py-3 liquid-glass hover:bg-blue-950/20 hover:text-blue-300 transition-all cursor-pointer animate-blur-fade-up" style="animation-delay: 800ms;" title="Investigations Archive">
              <ChevronLeft class="w-[18px] h-[18px] text-white" />
            </a>
            <!-- Next case arrow -->
            <a href="/new-investigation" class="flex items-center justify-center rounded-full px-4 sm:px-6 py-2.5 sm:py-3 liquid-glass hover:bg-blue-950/20 hover:text-blue-300 transition-all cursor-pointer animate-blur-fade-up" style="animation-delay: 900ms;" title="New Investigation">
              <ChevronRight class="w-[18px] h-[18px] text-white" />
            </a>
          </div>

        </div>
      </div>

    </div>

    <!-- Mobile Drawer Interactivity JavaScript -->
    <script>
      const hamburgerBtn = document.getElementById('hamburger-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      hamburgerBtn?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('translate-y-0');
        if (isOpen) {
          // Close Drawer
          mobileMenu?.classList.remove('translate-y-0', 'opacity-100', 'mobile-menu-open');
          mobileMenu?.classList.add('-translate-y-4', 'opacity-0', 'pointer-events-none');
          // Icon rotation & transitions
          menuIcon?.classList.remove('scale-50', 'opacity-0', 'rotate-180');
          closeIcon?.classList.add('scale-50', 'opacity-0', 'rotate-180');
        } else {
          // Open Drawer
          mobileMenu?.classList.add('translate-y-0', 'opacity-100', 'mobile-menu-open');
          mobileMenu?.classList.remove('-translate-y-4', 'opacity-0', 'pointer-events-none');
          // Icon rotation & transitions
          menuIcon?.classList.add('scale-50', 'opacity-0', 'rotate-180');
          closeIcon?.classList.remove('scale-50', 'opacity-0', 'rotate-180');
        }
      });
    </script>

  </body>
</html>
